# ---- Database (Supabase or Neon - free Postgres + pgvector) ----
# Supabase: Project Settings -> Database -> Connection string (use the pooled "Transaction" URL for serverless)
DATABASE_URL="postgres://user:pass@host:5432/postgres"

# ---- LLM (pick one; both are OpenAI-compatible) ----
# MODEL_PROVIDER = "deepseek" | "grok"
MODEL_PROVIDER="deepseek"
# DeepSeek: https://platform.deepseek.com  (base https://api.deepseek.com, model e.g. deepseek-chat)
DEEPSEEK_API_KEY=""
# Grok / xAI: https://console.x.ai  (base https://api.x.ai/v1, model e.g. grok-2-latest)
XAI_API_KEY=""
# Optional override of the model name; sensible defaults per provider are built in.
MODEL_NAME=""

# ---- Embeddings (pluggable, OpenAI-compatible endpoint) ----
# Cheapest reliable default: OpenAI text-embedding-3-small (1536 dims). Swap for Voyage/Jina/local if preferred.
EMBEDDINGS_BASE_URL="https://api.openai.com/v1"
EMBEDDINGS_API_KEY=""
EMBEDDINGS_MODEL="text-embedding-3-small"
EMBEDDINGS_DIM="1536"

# ---- Redis (Upstash - free serverless) ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Session (email login) ----
# Any long random string. Signs the session cookie. Set a real one for deploy.
SESSION_SECRET="change-me-to-a-long-random-string"

# ---- Credit economy ----
CHAT_PRICE="1"           # credits per chat message (~6 credits per 6 messages)
CHAPTER_PRICE="10"       # credits per generated / continued / rewritten story chapter
WELCOME_CREDITS="20"     # free credits on sign-up (~2 chapters, or 1 chapter + chat)
DAILY_DRIP="20"          # free credits granted once per day (tune for cost control)
REWARD_RATE="0.15"       # creator's share of readers' PURCHASED chat spend (0.15 = 15%),
                         # paid as earned (non-cashable) credits; accrues so fractions aren't lost

# ---- Deferred vendor stubs (leave blank until funded) ----
# PAYMENT_PROVIDER = "stub" | "stripe" | "segpay"
PAYMENT_PROVIDER="stub"
# AGE_VERIFY_PROVIDER = "attest" | "<vendor>"
AGE_VERIFY_PROVIDER="attest"

# ---- Explicit content tier (OFF by default; operator-configured) ----
# DO NOT set EXPLICIT_ENABLED=true until ALL of these are in place:
#   real age verification, the CSAM/illegal-content moderation pipeline,
#   an adult-permitting payment processor + host, and legal counsel sign-off.
# Enabling this without them is a legal/criminal-liability risk.
EXPLICIT_ENABLED="false"
# The separate model endpoint for the explicit lane (e.g. your Grok config or a
# self-hosted NSFW model). OpenAI-compatible.
EXPLICIT_MODEL_BASE_URL=""
EXPLICIT_MODEL_KEY=""
EXPLICIT_MODEL_NAME=""
# Operator-supplied system prompt for explicit story generation. YOU write this;
# it is intentionally not shipped. Left blank -> explicit falls back to standard.
EXPLICIT_SYSTEM_PROMPT_STORY=""
